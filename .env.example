#    (El archivo .env real jamás se subirá a GitHub por seguridad).
# ========================================================

# Token de acceso para los modelos de Inteligencia Artificial (GitHub Models u OpenAI)
GITHUB_PAT_TOKEN=tu_token_va_aqui
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
OPENAI_EMBEDDINGS_URL="https://models.github.ai/inference"
LANGSMITH_TRACING=""
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT=""